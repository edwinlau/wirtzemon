# Supabase — these are PUBLIC (publishable) values, safe for client bundles.
# The app also reads the same values from app.json -> expo.extra as a fallback,
# so copying this file to `.env` is optional.
EXPO_PUBLIC_SUPABASE_URL=https://myoswzctbxtvsdjakubm.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_KAQOX0hYKf9KRj5BXzTeZA_0iuSUUG0

# Google Maps — enables travel-time clash detection in the Schedule tab.
# Without it the app falls back to a time-gap heuristic. Restrict the key to the
# Distance Matrix API. (Long term this should move behind an Edge Function.)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# (Claude API calls in later phases are proxied through a Supabase Edge Function,
#  so no model API key ships in the client.)
